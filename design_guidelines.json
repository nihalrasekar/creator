  "instructions_to_main_agent": [
    "1. SETUP: Update tailwind.config.js to include the specific neon color palette and 'Space Grotesk' font family. Install 'react-icons' or '@phosphor-icons/react' for iconography.",
    "2. THEME: Ensure 'dark' class is applied to the html/body by default. The entire app is dark mode.",
    "3. GLASSMORPHISM: Do not use standard white cards. Use the provided 'glass_surface' classes for all cards in the dashboard and landing page.",
    "4. LAYOUT: For the Landing Page, break the grid. Do not use 3 equal columns. Use a 'Bento' style mixed grid (span-2, span-1).",
    "5. CHARTS: Use Recharts with custom tooltips that match the glassmorphism style (dark blurred background).",
    "6. MICRO-ANIMATIONS: Wrap page transitions in 'AnimatePresence' (Framer Motion). Add hover scales to all cards.",
    "7. IMAGES: Use the provided URLs for specific sections. Do not leave placeholders.",
    "8. STORE BUILDER: The 'Drag-drop' interface should use a distinct visual style (e.g., dotted grid background) to signify it's an editor workspace.",
    "9. TESTING: Add 'data-testid' to all buttons, inputs, and links."
  ],
  "universal_guidelines": [
    "Avoid 'AI Slop' (generic centered layouts).",
    "Use z-index hierarchy to create depth.",
    "No transparent backgrounds on headers without blur.",
    "Buttons must be pill-shaped or sharp-edged, never default rounded.",
    "Scrollbars must be customized (thin, dark)."
  ]
}